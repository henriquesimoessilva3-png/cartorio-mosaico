# Copie para .env.prod no servidor (NUNCA comitar)
# Use: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# Senha do Postgres — também forte (16+ chars)
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# (Opcional) domínio público — para Caddy/Traefik gerar HTTPS
DOMAIN=cartorio.exemplo.com.br
