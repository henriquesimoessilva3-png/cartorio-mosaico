# Copiar para .env e ajustar
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/cartorio_mosaico
SECRET_KEY=change-me-in-production-use-secrets-token-hex-32
DEBUG=true

# Tiles base do mapa (escolha um)
# Esri World Imagery não exige token (uso gratuito até volume corporativo)
TILE_PROVIDER=esri
# MAPBOX_TOKEN=pk.xxx           # se TILE_PROVIDER=mapbox

# Geocoder
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Azimute / projeção (defaults para Ferros, MG)
DEFAULT_UTM_EPSG=31983
DEFAULT_GEODETIC_EPSG=4674
